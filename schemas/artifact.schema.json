{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/airca-artifact.schema.json",
  "title": "AIRCA Artifact",
  "type": "object",
  "required": [
    "artifact_id",
    "title",
    "artifact_type",
    "status",
    "version",
    "created_at",
    "updated_at",
    "summary",
    "author",
    "scope"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+([._-][a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "type": "string",
      "enum": [
        "concept_repository",
        "concept_node",
        "framework_package",
        "schema",
        "validation",
        "example_artifact",
        "governance_policy",
        "note"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "deprecated",
        "archived"
      ]
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "created_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "updated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "author": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string"
        },
        "email": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "parent": {
      "type": "string"
    },
    "concept": {
      "type": "string"
    },
    "core_claim": {
      "type": "string"
    },
    "concepts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "related_concepts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "intellectual_lineage": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "original_contribution": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "attribution": {
      "type": "object",
      "additionalProperties": true
    },
    "source_docs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": true
}
